{
  "name": "test",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "nw-react-scripts": "2.0.0",
    "react": "^16.6.3",
    "react-dom": "^16.6.3"
  },
  "scripts": {
    "start": "nw-react-scripts start",
    "build": "nw-react-scripts build",
    "test": "nw-react-scripts test",
    "eject": "nw-react-scripts eject"
  },
  "eslintConfig": {
    "extends": "nw-react-app"
  },
  "browserslist": [
    "chrome >= 60"
  ],
  "main": "index.html",
